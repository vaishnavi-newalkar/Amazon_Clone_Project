# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/amazon_clone

# JWT Secret - change this in production!
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Debug
DEBUG=True

# Email (optional - set EMAIL_ENABLED=True with valid credentials)
EMAIL_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@amazonclone.com
